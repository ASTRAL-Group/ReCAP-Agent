# =========================
# Model / API
# =========================
# Required for remote model providers. Leave empty only if your local endpoint does not require auth.
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:8000/v1
OPENAI_MODEL=Qwen/Qwen3-VL-8B-Instruct
MODEL_MAX_COMPLETION_TOKENS=1024
MODEL_TEMPERATURE=0.8
MODEL_TOP_P=0.9

# CUA-specific model settings
OPENAI_CUA_MODEL=computer-use-preview
OPENAI_CUA_ENVIRONMENT=browser
OPENAI_CUA_REASONING_SUMMARY=
OPENAI_CUA_DISPLAY_WIDTH=1200
OPENAI_CUA_DISPLAY_HEIGHT=800

# =========================
# Providers
# =========================
DYNAMIC_PROVIDER_URL=http://localhost:5000
HALLIGAN_PROVIDER_URL=http://localhost:3334

# Dynamic CAPTCHA Provider per-type max calls
DYNAMIC_MAX_CALLS_IMAGE_GRID=8
DYNAMIC_MAX_CALLS_PAGED=6
DYNAMIC_MAX_CALLS_DEFAULT=4

# Halligan CAPTCHA Provider prepare delays (ms)
HALLIGAN_PREPARE_DELAY_RECAPTCHAV2=2000
HALLIGAN_PREPARE_DELAY_HCAPTCHA=2000
HALLIGAN_PREPARE_DELAY_ARKOSE=1000
HALLIGAN_PREPARE_DELAY_MTCAPTCHA=2000

# =========================
# Browser
# =========================
BROWSER_HEADLESS=true
BROWSER_VIEWPORT_WIDTH=1200
BROWSER_VIEWPORT_HEIGHT=800
BROWSER_SLOW_MO=50

# =========================
# Timing
# =========================
ACTION_DELAY_MS=150
POST_ACTION_DELAY_MS=400
HALLIGAN_RESPONSE_TIMEOUT=800

# =========================
# Runner
# =========================
RUNS_DIR=runs
LOG_LEVEL=INFO
MAX_CALLS=4
TEST_MODE=once
TEST_SIZE=2
# TEST_SEED can be blank for non-deterministic defaults
TEST_SEED=42
